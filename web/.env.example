# 환경변수 예시 — 복사하여 .env 로 사용
# PostgreSQL 연결 문자열 (로컬 Docker 또는 Neon/Supabase 등)
# Neon 예시: postgresql://user:pass@host.neon.tech/db?sslmode=require
# 로컬 예시: postgresql://postgres:postgres@localhost:5432/ishs_minwon
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ishs_minwon"

# 리로스쿨 인증 마이크로서비스 URL
# 운영에서는 별도 서버(VPS/Railway/Render 등)에 배포한 riro-auth 주소
RIRO_AUTH_URL="http://localhost:8000"

# JWT 세션 서명용 비밀키 — 반드시 강력한 랜덤 문자열 사용
# 생성: openssl rand -base64 32
SESSION_SECRET=""

# 개발 편의 가짜 로그인 — 운영에서는 반드시 false
ALLOW_DEV_LOGIN="false"

# 운영 환경 플래그 (쿠키 secure 속성 등에 영향)
NODE_ENV="production"
